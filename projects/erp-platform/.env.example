# erp-platform — local dev environment overrides
#
# Copy this file to .env to customize. .env is gitignored.
# Default values are baked into projects/erp-platform/docker-compose.yml.
# Hostname routing per ADR-MONO-001 Option C — no PORT_PREFIX needed.

# Hostname (must be present in /etc/hosts → 127.0.0.1)
PROJECT_HOSTNAME=erp.local

# GAP OIDC integration
# GAP exposes itself at http://gap.local/ via the shared Traefik stack.
# Start GAP with `pnpm gap:up` and the shared Traefik stack with
# `pnpm traefik:up`.
# OIDC_ISSUER_URL: GAP's issuer base URL — no trailing /oauth2/ path.
#   Spring Security appends /.well-known/openid-configuration automatically.
OIDC_ISSUER_URL=http://gap.local
# JWT_JWKS_URI: explicit JWKS endpoint (avoids OpenID discovery round-trip in dev).
JWT_JWKS_URI=http://gap.local/oauth2/jwks

# OIDC client credentials (erp-platform-internal-services-client,
# registered in GAP auth-service V0018).
# OIDC_INTERNAL_CLIENT_ID is fixed — must match the client_id seeded in V0018.
# OIDC_INTERNAL_CLIENT_SECRET is the dev plaintext password whose BCrypt hash is
# stored in V0018. NEVER commit the production secret here — rotate via the GAP
# admin API or by overriding via env var in production environments.
# WARNING: "erp-dev" is a dev-only credential for local/portfolio use.
#          Production deployments must replace this with a strong, randomly
#          generated secret and rotate via admin API / vault.
OIDC_INTERNAL_CLIENT_ID=erp-platform-internal-services-client
OIDC_INTERNAL_CLIENT_SECRET=erp-dev

# Tenant gate — gateway-service rejects tokens whose tenant_id != "erp".
OIDC_REQUIRED_TENANT_ID=erp

# Spring profile (default | standalone | prod)
SPRING_PROFILES_ACTIVE=default

# MySQL — internal to erp-platform-net, no host port published.
# masterdata-service uses erp_db (TASK-ERP-BE-001 lands the Flyway schema).
MYSQL_DB=erp_db
MYSQL_USER=erp
MYSQL_PASSWORD=erp
MYSQL_ROOT_PASSWORD=root

# Redis — internal to erp-platform-net, no host port published.
# Leave blank for dev; set for staging/prod and ensure REDIS_PASSWORD reaches
# all services via their service environment.
REDIS_PASSWORD=

# CORS allowed origins (comma-separated). The gateway echoes these to
# preflight responses; production must use real hostnames only.
# v1 = backend only — erp UI is rendered by the unified platform console
# (ADR-MONO-013 §3.3); no erp-platform-web frontend.
CORS_ALLOWED_ORIGINS=http://erp.local
