# fan-platform — local dev environment overrides
#
# Copy this file to .env to customize. .env is gitignored.
# Default values are baked into projects/fan-platform/docker-compose.yml.
# Hostname routing per ADR-MONO-001 Option C — no PORT_PREFIX needed.

# Hostname (must be present in /etc/hosts → 127.0.0.1)
PROJECT_HOSTNAME=fan-platform.local

# GAP OIDC integration
# In dev with Traefik running, GAP exposes itself at http://gap.local/
# (after TASK-MONO-024 migrates GAP to hostname routing — until then,
# GAP runs at http://localhost:38080 via legacy PORT_PREFIX=3).
OIDC_ISSUER_URL=http://gap.local
JWT_JWKS_URI=http://gap.local/.well-known/jwks.json

# Spring profile (default | standalone | prod)
SPRING_PROFILES_ACTIVE=default

# Postgres — internal to fan-platform-net, no host port published.
# Currently unused by gateway-service but kept here for downstream services
# bootstrapped in subsequent tasks (community / artist).
POSTGRES_USER=fanplatform
POSTGRES_PASSWORD=fanplatform
POSTGRES_DB=fanplatform

# Redis — internal to fan-platform-net, no host port published.
# Leave blank for dev; set for staging/prod and ensure REDIS_PASSWORD reaches
# the gateway service via its environment.
REDIS_PASSWORD=

# CORS allowed origins (comma-separated). The gateway echoes these to
# preflight responses; production must use real frontend hostnames only.
CORS_ALLOWED_ORIGINS=http://fan-platform.local,http://localhost:3000
