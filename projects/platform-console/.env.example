# platform-console — local dev environment (copy to .env)
# ADR-MONO-013 Phase 1 skeleton. The OIDC/registry values are wired but the
# real SSO + data-driven catalog flow lands in TASK-PC-FE-001 (Phase 2),
# and the GAP-side client/registry is provisioned by TASK-BE-296.

NODE_ENV=production

# GAP OIDC public client (Authorization Code + PKCE)
OIDC_ISSUER_URL=http://gap.local
OIDC_CLIENT_ID=platform-console-web
OIDC_REDIRECT_URI=http://console.local/api/auth/callback

# GAP product/tenant registry surface — data-driven catalog source
CONSOLE_REGISTRY_URL=http://gap.local/internal/console/registry
