# platform-console — local dev environment (copy to .env)
# ADR-MONO-013. Real GAP OIDC SSO + data-driven catalog (TASK-PC-FE-001).
# GAP-side OIDC client + registry surface provisioned by TASK-BE-296.

NODE_ENV=production

# GAP OIDC PUBLIC client (Authorization Code + PKCE — no client secret;
# auth-service V0015 seed / ADR-003 public-client lineage).
OIDC_ISSUER_URL=http://gap.local
OIDC_CLIENT_ID=platform-console-web
OIDC_REDIRECT_URI=http://console.local/api/auth/callback
# Subset of the V0015-seeded client scopes.
OIDC_SCOPE=openid profile email tenant.read

# GAP product/tenant registry surface — data-driven catalog source.
# AUTHORITATIVE producer path (TASK-BE-296 / console-registry-api.md):
#   admin-service GET /api/admin/console/registry behind the operator-auth
#   boundary (gateway treats /api/admin/** as a public-path subtree and
#   delegates operator JWT verification to admin-service). The console calls
#   it server-side with the EXCHANGED operator token (NOT the GAP OIDC token
#   — see CONSOLE_TOKEN_EXCHANGE_URL).
CONSOLE_REGISTRY_URL=http://gap.local/api/admin/console/registry

# Outbound timeout (ms) for the registry call (integration-heavy resilience).
REGISTRY_TIMEOUT_MS=5000

# GAP admin-service RFC 8693 operator-token exchange surface.
# AUTHORITATIVE producer path (TASK-BE-298 / admin-api.md / ADR-MONO-014):
#   admin-service POST /api/admin/auth/token-exchange on the same
#   /api/admin/** operator-auth public-path subtree. The console server-side
#   exchanges the GAP OIDC access token (subject_token) for a short-lived
#   operator token (token_type=admin). The GAP OIDC token is never an
#   /api/admin/** credential (console-integration-contract § 2.1/§ 2.6).
CONSOLE_TOKEN_EXCHANGE_URL=http://gap.local/api/admin/auth/token-exchange

# Outbound timeout (ms) for the operator-token exchange call.
TOKEN_EXCHANGE_TIMEOUT_MS=5000
