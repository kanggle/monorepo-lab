# admin-web environment variables
# Copy this file to .env.local and adjust values for your local setup

# API backend URL
# Local development: http://localhost:8080
# E2E testing profile: http://localhost:18080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Application URL (used for redirects, cookies, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Grafana dashboard URLs (client-side)
# Placeholder URLs for local development when Grafana is not available
# Update these URLs to point to your actual Grafana instance in production
NEXT_PUBLIC_GRAFANA_ACCOUNTS_URL=http://localhost:9999/grafana-not-configured
NEXT_PUBLIC_GRAFANA_SECURITY_URL=http://localhost:9999/grafana-not-configured
NEXT_PUBLIC_GRAFANA_SYSTEM_URL=http://localhost:9999/grafana-not-configured

# Server-side logging level (only read by server runtime)
LOG_LEVEL=info
