# =============================================================================
# Global Account Platform — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Default values are set so that `docker compose up -d` works without .env.
# =============================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_PORT=3306

# --- MySQL Service User Passwords ---
AUTH_DB_PASSWORD=auth_pass
ACCOUNT_DB_PASSWORD=account_pass
SECURITY_DB_PASSWORD=security_pass
ADMIN_DB_PASSWORD=admin_pass

# --- Redis ---
REDIS_PASSWORD=redispass
REDIS_PORT=6379

# --- Kafka (KRaft) ---
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg
KAFKA_EXTERNAL_PORT=9093

# --- Kafka UI ---
KAFKA_UI_PORT=8090

# --- OAuth Social Login (auth-service) ---
# Leave defaults for local/WireMock-based tests. Override for real provider login.
#
# OAUTH_<P>_ALLOWED_REDIRECT_URIS — comma-separated server-side allowlist.
# Server validates the client-supplied redirectUri with EXACT-string match
# against this list (no normalization, no prefix). At least one entry must
# include the URI exposed by the front-end. If unset, falls back to the
# single OAUTH_<P>_REDIRECT_URI value (legacy behaviour).
#
# Google: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
OAUTH_GOOGLE_CLIENT_ID=test-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=test-google-client-secret
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
OAUTH_GOOGLE_ALLOWED_REDIRECT_URIS=http://localhost:3000/oauth/callback

# Kakao: https://developers.kakao.com → 내 애플리케이션 → REST API 키
OAUTH_KAKAO_CLIENT_ID=test-kakao-client-id
OAUTH_KAKAO_CLIENT_SECRET=test-kakao-client-secret
OAUTH_KAKAO_REDIRECT_URI=http://localhost:3000/oauth/callback
OAUTH_KAKAO_ALLOWED_REDIRECT_URIS=http://localhost:3000/oauth/callback

# Microsoft: https://portal.azure.com → App registrations → New registration
#   Tenant: common (personal + work), organizations (work only), consumers (personal only), or specific tenant ID
OAUTH_MICROSOFT_CLIENT_ID=test-microsoft-client-id
OAUTH_MICROSOFT_CLIENT_SECRET=test-microsoft-client-secret
OAUTH_MICROSOFT_REDIRECT_URI=http://localhost:3000/oauth/callback
OAUTH_MICROSOFT_ALLOWED_REDIRECT_URIS=http://localhost:3000/oauth/callback
OAUTH_MICROSOFT_TENANT=common

# --- Auth-service rate limits ---
# Login failure counter (per email-hash window). Production defaults — relax with
# care; the window doubles as the soft account-lock period at the application layer.
LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW=900

# TASK-BE-144: password-reset request flood protection. Increment runs before the
# credential lookup so the same window applies to existing and unknown emails
# alike (no enumeration via response timing). Overflow is silently absorbed —
# the controller still replies 204.
PASSWORD_RESET_WINDOW=900
PASSWORD_RESET_MAX_ATTEMPTS=3
