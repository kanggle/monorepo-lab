# ============================================================
# 로컬 개발용 환경변수 (.env)
# 이 파일을 .env로 복사한 뒤 값을 채워서 사용하세요
# .env 파일은 git에 커밋하지 마세요 (개발 전용 시크릿 포함)
# 프로덕션 시크릿은 Vault / AWS Secrets Manager로 관리
# ============================================================

# JWT 시크릿 — auth-service 와 gateway-service 가 공유
# 최소 32자 이상 필요
JWT_SECRET=

# ──────────────────────────────────────────────
# Gateway CORS 허용 origin (콤마 구분)
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────────────
# PostgreSQL 비밀번호 (서비스별)
# ──────────────────────────────────────────────
AUTH_DB_PASSWORD=
PRODUCT_DB_PASSWORD=
ORDER_DB_PASSWORD=
PAYMENT_DB_PASSWORD=
USER_DB_PASSWORD=
BATCH_DB_PASSWORD=

# ──────────────────────────────────────────────
# Grafana
# ──────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=

# ──────────────────────────────────────────────
# MinIO (S3 호환 객체 스토리지 — 상품 이미지)
# specs/platform/object-storage-policy.md
# ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
PRODUCT_IMAGES_BUCKET=firstproject-local-product-images
