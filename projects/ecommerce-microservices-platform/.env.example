# ============================================================
# 로컬 개발용 환경변수 (.env)
# 이 파일을 .env로 복사한 뒤 값을 채워서 사용하세요
# .env 파일은 git에 커밋하지 마세요 (개발 전용 시크릿 포함)
# 프로덕션 시크릿은 Vault / AWS Secrets Manager로 관리
# ============================================================

# ──────────────────────────────────────────────
# 포트 네임스페이스 (monorepo 규약 — TEMPLATE.md 참조)
# ──────────────────────────────────────────────
# docker-compose 의 모든 host 포트 앞에 이 한 자리 숫자가 prefix 로 붙는다.
#   1 → 1XXXX (기본값, 예: Postgres 15432, Gateway 18080, web-store 13000)
#   2 → 2XXXX (wms-platform 이 사용 중)
#   3~6 → 향후 프로젝트용
#   빈 문자열 → prefix 없이 원래 포트 사용 (단독 기동 시, standalone 레포 느낌)
# monorepo 안에서 wms 와 동시 기동하려면 이 값 그대로 둘 것.
# 예외: Jaeger UI 의 호스트 포트 16686 은 5자리라 prefix 가 적용되지 않음.
PORT_PREFIX=1

# JWT 시크릿 — auth-service 와 gateway-service 가 공유
# 최소 32자 이상 필요
JWT_SECRET=

# ──────────────────────────────────────────────
# Gateway CORS 허용 origin (콤마 구분)
# 기본값은 PORT_PREFIX=1 기준 (web-store 13000, admin-dashboard 13001)
# PORT_PREFIX 를 바꾸면 이 값도 같이 맞출 것
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:13000,http://localhost:13001

# ──────────────────────────────────────────────
# PostgreSQL 비밀번호 (서비스별)
# ──────────────────────────────────────────────
AUTH_DB_PASSWORD=
PRODUCT_DB_PASSWORD=
ORDER_DB_PASSWORD=
PAYMENT_DB_PASSWORD=
USER_DB_PASSWORD=
BATCH_DB_PASSWORD=

# ──────────────────────────────────────────────
# Grafana
# ──────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=

# ──────────────────────────────────────────────
# MinIO (S3 호환 객체 스토리지 — 상품 이미지)
# specs/platform/object-storage-policy.md
# ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
PRODUCT_IMAGES_BUCKET=firstproject-local-product-images
