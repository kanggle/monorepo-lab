# ============================================================
# 로컬 개발용 환경변수 (.env)
# 이 파일을 .env로 복사한 뒤 값을 확인/조정해서 사용하세요
# .env 파일은 git에 커밋하지 마세요 (개발 전용 시크릿 포함)
# 프로덕션 시크릿은 Vault / AWS Secrets Manager로 관리
#
# ⚠️  아래의 "changeme-local" 접미사가 붙은 값은 **로컬 개발 전용** 기본값입니다.
#     프로덕션/스테이징에 배포하기 전 반드시 고유한 값으로 교체하세요.
# ============================================================

# ──────────────────────────────────────────────
# 호스트네임 라우팅 (ADR-MONO-001 Option C, TASK-MONO-024)
# ──────────────────────────────────────────────
# Traefik 가 `ecommerce.local` 호스트로 들어오는 트래픽을 gateway-service 로 라우팅한다.
# 사전 준비:
#   1) bash scripts/dev-setup.sh  (또는 Windows: .\scripts\dev-setup.ps1) — *.local hosts 등록
#   2) pnpm traefik:up            — 공유 Traefik 스택 기동
# 변경 시 README, CORS_ALLOWED_ORIGINS, OAUTH_CALLBACK_ALLOWLIST 의 호스트도 함께 갱신.
PROJECT_HOSTNAME=ecommerce.local

# 브라우저에서 사용하는 절대 API URL (web-store / admin-dashboard 빌드 시 baked-in)
# 기본값은 PROJECT_HOSTNAME 기준. 변경 시 같이 맞출 것.
NEXT_PUBLIC_API_URL=http://ecommerce.local

# JWT 시크릿 — auth-service 와 gateway-service 가 공유
# 최소 32자 이상 필요
JWT_SECRET=changeme-local-dev-only-min-32-characters-padding

# ──────────────────────────────────────────────
# Gateway CORS 허용 origin (콤마 구분)
# 기본값은 Traefik 호스트네임 기반 (web.ecommerce.local, admin.ecommerce.local).
# 다른 호스트네임에서 접근하려면 함께 맞출 것.
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://ecommerce.local,http://web.ecommerce.local,http://admin.ecommerce.local

# ──────────────────────────────────────────────
# OAuth callbackUrl 허용 목록 (콤마 구분)
# Traefik 호스트네임 기준. 변경 시 같이 맞출 것.
# ──────────────────────────────────────────────
OAUTH_CALLBACK_ALLOWLIST=http://web.ecommerce.local/oauth/callback

# ──────────────────────────────────────────────
# PostgreSQL 비밀번호 (서비스별)
# ──────────────────────────────────────────────
AUTH_DB_PASSWORD=changeme-local
PRODUCT_DB_PASSWORD=changeme-local
ORDER_DB_PASSWORD=changeme-local
PAYMENT_DB_PASSWORD=changeme-local
USER_DB_PASSWORD=changeme-local
BATCH_DB_PASSWORD=changeme-local
SHIPPING_DB_PASSWORD=changeme-local
REVIEW_DB_PASSWORD=changeme-local
PROMOTION_DB_PASSWORD=changeme-local
NOTIFICATION_DB_PASSWORD=changeme-local

# ──────────────────────────────────────────────
# Grafana
# ──────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme-local

# ──────────────────────────────────────────────
# MinIO (S3 호환 객체 스토리지 — 상품 이미지)
# platform/object-storage-policy.md 참조
# MinIO 의 MINIO_ROOT_* 는 최소 8자 필요
# ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-changeme-local
PRODUCT_IMAGES_BUCKET=firstproject-local-product-images

# ──────────────────────────────────────────────
# auth-service — prod 초기 관리자 계정 비밀번호
# AdminAccountSeeder는 local/standalone 프로파일에서만 실행된다.
# prod에서 최초 관리자 계정이 필요한 경우 이 값을 설정하고
# bootstrap 스크립트로 계정을 직접 생성하라.
# ──────────────────────────────────────────────
ADMIN_INITIAL_PASSWORD=changeme-admin
