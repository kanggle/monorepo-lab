{
  "uid": "business-metrics",
  "title": "Business Metrics",
  "tags": ["business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 100,
      "title": "Auth Service",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Signups",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "increase(auth_signup_total{job=\"auth-service\"}[1h])",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Logins (success/failure)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(auth_login_total{job=\"auth-service\"}[5m])",
          "legendFormat": "login total",
          "refId": "A"
        },
        {
          "expr": "rate(auth_login_failure_total{job=\"auth-service\"}[5m])",
          "legendFormat": "failure ({{reason}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Token Refresh / Logout / Session Eviction",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(auth_token_refresh_total{job=\"auth-service\"}[5m])",
          "legendFormat": "token refresh",
          "refId": "A"
        },
        {
          "expr": "rate(auth_logout_total{job=\"auth-service\"}[5m])",
          "legendFormat": "logout",
          "refId": "B"
        },
        {
          "expr": "rate(auth_session_eviction_total{job=\"auth-service\"}[5m])",
          "legendFormat": "session eviction",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 200,
      "title": "Gateway Service",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 4,
      "title": "Routed Requests by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
