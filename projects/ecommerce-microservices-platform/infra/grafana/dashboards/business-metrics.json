      "targets": [
        {
          "expr": "rate(gateway_requests_routed_total{job=\"gateway-service\"}[5m])",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Rate Limited / JWT Failures / Upstream Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(gateway_rate_limited_total{job=\"gateway-service\"}[5m])",
          "legendFormat": "rate limited ({{route}})",
          "refId": "A"
        },
        {
          "expr": "rate(gateway_jwt_validation_failure_total{job=\"gateway-service\"}[5m])",
          "legendFormat": "jwt failure ({{reason}})",
          "refId": "B"
        },
        {
          "expr": "rate(gateway_upstream_error_total{job=\"gateway-service\"}[5m])",
          "legendFormat": "upstream error ({{service}})",
          "refId": "C"
        }
