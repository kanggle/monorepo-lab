          "refId": "A"
        },
        {
          "expr": "rate(order_amount_sum{job=\"order-service\"}[5m])",
          "legendFormat": "revenue rate",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 500,
      "title": "Payment Service",
