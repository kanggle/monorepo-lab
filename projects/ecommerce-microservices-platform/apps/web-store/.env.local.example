# web-store frontend environment — copy to `.env.local` for local dev.
# After TASK-FE-067 the auth flow is GAP OIDC + NextAuth v5 (PKCE).
#
# Generate NEXTAUTH_SECRET with `openssl rand -base64 32`. The value just needs
# to be stable across server restarts so JWT cookies stay decryptable.
NEXTAUTH_SECRET=replace-me-with-32-bytes-base64
NEXTAUTH_URL=http://localhost:3000

# GAP (global-account-platform) OIDC issuer. In dev: http://gap.local
# (Traefik) or http://localhost:18080/gap depending on the docker-compose
# setup. The OIDC discovery doc lives at $OIDC_ISSUER_URL/.well-known/openid-configuration
OIDC_ISSUER_URL=http://gap.local

# GAP V0012 seed registers `ecommerce-web-store-client` with secret `ecommerce-dev`
# (plaintext, dev-only). Override for prod.
ECOMMERCE_WEB_STORE_CLIENT_ID=ecommerce-web-store-client
ECOMMERCE_WEB_STORE_CLIENT_SECRET=ecommerce-dev

# Backend gateway URL — same as before TASK-FE-067.
NEXT_PUBLIC_API_URL=http://localhost:8080
API_URL_INTERNAL=http://localhost:8080
