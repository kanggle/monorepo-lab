# admin-dashboard frontend environment — copy to `.env.local` for local dev.
# After TASK-FE-067 the auth flow is GAP OIDC + NextAuth v5 (PKCE).
NEXTAUTH_SECRET=replace-me-with-32-bytes-base64
NEXTAUTH_URL=http://localhost:3001

# GAP (global-account-platform) OIDC issuer.
OIDC_ISSUER_URL=http://gap.local

# GAP V0012 seed registers `ecommerce-admin-dashboard-client` with secret
# `ecommerce-dev` (plaintext, dev-only). Override for prod.
ECOMMERCE_ADMIN_DASHBOARD_CLIENT_ID=ecommerce-admin-dashboard-client
ECOMMERCE_ADMIN_DASHBOARD_CLIENT_SECRET=ecommerce-dev

# Backend gateway URL.
NEXT_PUBLIC_API_URL=http://localhost:8080
