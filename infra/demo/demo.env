# =============================================================================
# infra/demo/demo.env — 통합 데모 전용 cross-project 환경변수 (TASK-MONO-344)
# =============================================================================
# demo-up.sh 가 이 파일을 source 한 뒤 각 프로젝트 compose 를 기동한다.
# 프로젝트 compose 파일은 byte-unchanged 로 두고, 데모 토폴로지에 필요한 값만
# 여기서 주입한다.
#
# 토폴로지: 각 프로젝트가 자기 compose 프로젝트(-p <slug>)로 뜨고, 공유 external
# `traefik-net` 위에서 서로의 container_name 으로 DNS 해소한다.
# =============================================================================

# =============================================================================
# --- DEMO_DOMAIN — 데모가 어느 호스트명으로 서빙되는가 (TASK-MONO-358)
# =============================================================================
# Traefik 라우터는 `Host(`console.${DEMO_DOMAIN:-local}`)` 형태다.
#
#   로컬:  DEMO_DOMAIN=local          → console.local  (hosts 파일 → 127.0.0.1)
#   EC2 :  DEMO_DOMAIN=<ip>.sslip.io  → console.3-36-44-101.sslip.io
#
# sslip.io 는 `<anything>.1-2-3-4.sslip.io` → 1.2.3.4 로 해석되는 공개 와일드카드
# DNS 다. 도메인 구매도 DNS 레코드 설정도 필요 없다. 인스턴스에 EIP 가 없어 start
# 마다 공인 IP 가 바뀌므로, 클라우드에서는 **부팅 시 IMDS 로 읽어 주입**한다.
#
# 여기 기본값이 `local` 이므로 개발자 로컬 렌더는 변경 전과 바이트 동일하다.
DEMO_DOMAIN=local

# --- redis -------------------------------------------------------------------
# wms/iam 앱은 REDIS_PASSWORD env 를 읽지 않는다. base compose 의 redis 가
# ${REDIS_PASSWORD} 로 requirepass 를 걸므로, 데모에서는 비워 둔다. (MONO-342)
REDIS_PASSWORD=

# =============================================================================
# --- 도메인 간 신원(OIDC) — issuer 와 jwks 를 **분리**한다 (TASK-MONO-358)
# =============================================================================
# 이것이 이 파일에서 가장 미묘한 부분이다. 두 URL 은 성질이 다르다:
#
#   issuer      = 토큰의 `iss` 클레임과 **문자열 비교**된다. 동시에 브라우저가
#                 OIDC 인가 엔드포인트로 리다이렉트되어 **실제로 도달해야** 하는
#                 주소이기도 하다  → 공개 호스트명이어야 한다.
#   jwk-set-uri = 리소스 서버가 **실제로 fetch** 한다 → 컨테이너 DNS 가 맞다.
#
# 뒤집으면 둘 다 깨진다:
#   · jwks 를 공개 호스트명으로 두면 — AWS 는 인스턴스가 **자기 공인 IP** 로 보내는
#     트래픽을 되돌려주지 않는다(IGW hairpin 부재) → JWKS fetch 가 죽는다.
#   · issuer 를 컨테이너 DNS 로 두면 — 브라우저가 인가 엔드포인트에 도달할 수 없다.
#     (이것이 MONO-358 이전의 상태였다: iam 은 `iss=http://auth-service:8081` 을
#      발급하고 있었고, 콘솔은 `http://iam.local` 을 기대했으며, 그 호스트를 서빙하는
#      **라우터는 존재하지도 않았다.** 96 컨테이너가 healthy 로 떠도 로그인은 불가능.)
#
# `iam.${DEMO_DOMAIN}` 이 컨테이너 안에서도 해소되는 이유는 Traefik 컨테이너에 건
# network alias 다 (infra/traefik/docker-compose.yml).
IAM_PUBLIC_URL=http://iam.${DEMO_DOMAIN}
IAM_JWKS_URL=http://iam-auth-service:8081/oauth2/jwks

# scm / fan / finance / erp 는 **제네릭 이름**을 읽는다(각 compose 의
# `${OIDC_ISSUER_URL:-...}` / `${JWT_JWKS_URI:-...}`). iam 이 실제로 발급하는 iss 와
# 반드시 같아야 한다 — 그래서 iam 쪽도 같은 값으로 맞춘다
# (infra/demo/iam-traefik.override.yml).
OIDC_ISSUER_URL=${IAM_PUBLIC_URL}
JWT_JWKS_URI=${IAM_JWKS_URL}

# --- wms → iam OIDC ----------------------------------------------------------
# wms 는 자기 접두사(WMS_*)를 쓴다.
WMS_OIDC_ISSUER_URL=${IAM_PUBLIC_URL}
WMS_OIDC_JWK_SET_URI=${IAM_JWKS_URL}
WMS_OIDC_ALLOWED_ISSUERS=${IAM_PUBLIC_URL}
WMS_CORS_ALLOWED_ORIGINS=http://console.${DEMO_DOMAIN}

# --- platform-console ---------------------------------------------------------
# console-web 은 OIDC 코드 교환을 **서버사이드**로 한다 → `${OIDC_ISSUER_URL}` 이
# 컨테이너 안에서도 해소돼야 한다(Traefik alias 가 그 일을 한다).
# 리다이렉트 URI 는 **브라우저가 되돌아오는 곳**이므로 반드시 공개 호스트명이다.
OIDC_REDIRECT_URI=http://console.${DEMO_DOMAIN}/api/auth/callback
CONSOLE_REGISTRY_URL=${IAM_PUBLIC_URL}/api/admin/console/registry
CONSOLE_TOKEN_EXCHANGE_URL=${IAM_PUBLIC_URL}/api/admin/auth/token-exchange
CONSOLE_BFF_IAM_ISSUER_URL=${IAM_PUBLIC_URL}

# --- wms outbound 외부 스텁 (ADR-MONO-005 category D) -------------------------
WMS_TMS_BASE_URL=http://localhost:9999
WMS_TMS_API_KEY=demo

# --- wms notification Slack 스텁 (CB 로 degrade) -------------------------------
WMS_SLACK_ALERTS_URL=http://localhost:9999/alerts
WMS_SLACK_SHIPPING_URL=http://localhost:9999/shipping

# --- ecommerce (MONO-346) ----------------------------------------------------
# ecommerce compose 는 기본값 없는 bare ${VAR} 를 14개 참조한다. 그 값의 출처인
# projects/ecommerce-microservices-platform/.env 는 gitignored 이므로 갓 clone 한
# 트리(데모 AMI, CI 러너)에서는 전부 빈 문자열로 보간된다.
#
# 그 중 9개가 POSTGRES_PASSWORD 다. postgres:16-alpine 은 빈 superuser 비밀번호로
# 초기화를 거부하므로("Database is uninitialized and superuser password is not
# specified"), ecommerce DB 9개가 기동 실패하고 그 위의 앱 12개가 전부 죽는다.
# compose 는 미설정 변수를 error 가 아닌 **warning** 으로 처리하기 때문에 렌더
# 검사(가드 a)는 이를 통과시킨다 → 가드 (g)가 경고를 에러로 승격한다.
#
# 여기 값을 두는 이유: 프로젝트 compose 를 `${VAR:-default}` 로 바꾸면 **운영
# 배포에서 빈 비밀번호가 조용히 통과**한다. 데모 값 주입은 데모 파일의 책임이다.
# 셸 env 는 compose 의 .env 파일보다 우선하므로 실 .env 를 가진 개발자도 데모
# 실행 중에는 아래 값이 적용된다 (REDIS_PASSWORD= 와 동일한 패턴).
#
# host port 를 열지 않고(expose: only) Traefik 뒤에 있으므로 리터럴 커밋이 안전하다.
PRODUCT_DB_PASSWORD=changeme-local
ORDER_DB_PASSWORD=changeme-local
PAYMENT_DB_PASSWORD=changeme-local
USER_DB_PASSWORD=changeme-local
BATCH_DB_PASSWORD=changeme-local
SHIPPING_DB_PASSWORD=changeme-local
REVIEW_DB_PASSWORD=changeme-local
PROMOTION_DB_PASSWORD=changeme-local
NOTIFICATION_DB_PASSWORD=changeme-local
# .env.example 에 선언 자체가 누락돼 있던 변수 (MONO-346 이 함께 보강)
SETTLEMENT_DB_PASSWORD=changeme-local
GRAFANA_ADMIN_PASSWORD=changeme-local
CORS_ALLOWED_ORIGINS=http://ecommerce.${DEMO_DOMAIN},http://web.ecommerce.${DEMO_DOMAIN},http://console.${DEMO_DOMAIN}
# TOSS 결제 게이트웨이 — 데모는 결제 승인까지 가지 않으므로 더미. 실키를 넣지 말 것.
TOSS_PAYMENTS_SECRET_KEY=test_sk_demo_not_a_real_key
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_demo_not_a_real_key

# --- JVM 힙 캡 (미해결) --------------------------------------------------------
# 실측(MONO-342): 힙 상한 없는 갓 기동 JVM 은 컨테이너 메모리의 1/4 까지 팽창해
# master-service 하나가 762 MiB 를 썼다. 40개 동시 기동 시 데모 호스트 사이징을
# 좌우한다.
#
# 그런데 여기서 캡을 걸 수 없다: 각 프로젝트 compose 는 byte-unchanged 로 두므로
# JAVA_TOOL_OPTIONS 를 참조하는 `${VAR}` 자리가 없다. 셸 env 는 compose 가
# 명시적으로 보간하지 않으면 컨테이너로 전달되지 않는다.
#
# 해법은 둘 중 하나이며 별도 증분이다:
#   (1) 데모 호스트를 넉넉히(32GB) 잡는다 — 현재 선택
#   (2) 각 프로젝트 compose 에 `JAVA_TOOL_OPTIONS: ${JAVA_TOOL_OPTIONS:-}` 를 추가
#       (byte-unchanged 포기, 8개 파일 수정)
