# cp terraform.tfvars.example terraform.tfvars 후 값 채우기.
#
# ⚠️ `terraform.tfvars` 는 gitignore 다 — 본인 공인 IP 가 들어가므로 커밋하지 말 것.
#
# 자격증명은 **환경변수 또는 `~/.aws/credentials`** 로 준다
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION).
# **비밀 키를 이 파일에 적지 말 것** — tfvars 는 평문이다.

region  = "ap-northeast-2"
project = "portfolio-demo"

# 사전에 packer 로 구운 AMI — 유일한 필수 항목.
#   cd ../packer && packer build demo-ami.pkr.hcl
ami_id = "ami-xxxxxxxxxxxxxxxxx"

# 사이징 — **TASK-MONO-366** 의 1회 관측치다(이전 판은 이 값을 TASK-MONO-353 의 것이라
# 적었는데, 353 은 `bitnami/kafka:3.7` 삭제 티켓이다).
#   `full` ≈ **96 컨테이너 / 메모리 ~26GB**(JVM 40+), m6i.2xlarge(32GB) 에서 **여유 ~5.5GB**.
#   (이전 문서의 "43 컨테이너 / 21GB 여유" 는 `bitnami/kafka:3.7` 삭제로 33개만 뜬
#    **고장난 스택**을 잰 값이었다. 죽은 이미지가 6개 프로젝트를 막고 있었다.)
#
# 🔴 **이 숫자는 상한이 아니다 — 아무것도 강제하지 않는 관측치다.** 메모리 리밋을 선언하는
#    것은 **35개(2개 프로젝트)뿐** — ecommerce 34(전 서비스) + finance kafka 1(FIN-BE-059).
#    나머지 6개 프로젝트는 리밋이 **0개** ⇒ 천장이 없다.
#    ✅ 재측정 완료 = TASK-MONO-399 AC-2 (2026-07-23): full=86 서비스/98 컨테이너, used ~28GB/
#    여유 ~2.8GB (as-baked 3중 크래시루프 중 관측 — clean 측정은 AC-6 재굽기 후).
#    ⚠️ 그렇다고 "일관성 있게" 리밋을 추가하지 마라 — 리밋은 상한이 아니라 **설정**이다
#    (JAVA_OPTS 없는 JVM 은 힙을 cgroup 리밋의 25% 로 잡는다). TASK-MONO-397 참조.
#
# 여유를 원하면 m6i.4xlarge(64GB) — 단 월 예산 상한(600분) 하에서 최대 ~$10.
instance_type = "m6i.2xlarge"

# (선택) 비우면 default VPC + 그 첫 퍼블릭 서브넷을 자동 탐색한다.
vpc_id    = ""
subnet_id = ""

# 본인 IP/32 로 좁힐 것. `0.0.0.0/0` 은 SSH 를 전 세계에 여는 것이다.
admin_ssh_cidr = "1.2.3.4/32"

# AMI 이미지 + 도커 레이어 + 96 컨테이너 로그.
root_volume_gb = 100

# CORS 허용 오리진. **비워두는 것이 권장값이다** — terraform 이 사이트 자신의
# CloudFront 도메인으로 채운다. 그 값은 배포 시점에야 정해지므로 손으로 박을 수 없다.
#
# 예전에는 여기가 `allowed_origin = "*"` 였다. 주석은 "좁히는 것을 권장" 이라 말하면서
# 코드는 넓혀 놓았고, 이 파일을 그대로 복사해 쓰는 것이 README 가 시키는 절차다
# ⇒ 권장을 따른 사람이 와일드카드를 얻었다 (TASK-MONO-389).
#
# index.html 을 file:// 로 열어 로컬 디버깅할 때만 "*" 를 명시하라.
# allowed_origin = ""

# --- 지출 상한 --------------------------------------------------------------
# `/start` 는 **공개 엔드포인트**다. 가드 없이 두면 무제한 지출 버튼이 된다.
# 세 겹으로 막는다:
#   idle_minutes           — 마지막 하트비트 후 N 분 유휴면 정지
#   max_runtime_minutes    — 한 세션의 절대 상한(하트비트가 계속 와도 정지)
#   monthly_budget_minutes — **월 누적 가동 분**. 소진되면 `/start` 가 429 를 반환하고
#                            인스턴스를 켜지 않는다. 앞의 둘만으로는 부족하다 —
#                            누가 매일 세 시간씩 켜도 각 세션은 규칙을 지킨다.
idle_minutes           = 20
max_runtime_minutes    = 180
monthly_budget_minutes = 600
