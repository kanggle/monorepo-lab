# cp terraform.tfvars.example terraform.tfvars 후 값 채우기.
#
# ⚠️ `terraform.tfvars` 는 gitignore 다 — 본인 공인 IP 가 들어가므로 커밋하지 말 것.
#
# 자격증명은 **환경변수 또는 `~/.aws/credentials`** 로 준다
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION).
# **비밀 키를 이 파일에 적지 말 것** — tfvars 는 평문이다.

region  = "ap-northeast-2"
project = "portfolio-demo"

# 사전에 packer 로 구운 AMI — 유일한 필수 항목.
#   cd ../packer && packer build demo-ami.pkr.hcl
ami_id = "ami-xxxxxxxxxxxxxxxxx"

# 사이징 — TASK-MONO-353 이 **실측으로 정정**했다.
#   `full` = **96 컨테이너 / 메모리 ~26GB**(JVM 40+).
#   (이전 문서의 "43 컨테이너 / 21GB 여유" 는 `bitnami/kafka:3.7` 삭제로 33개만 뜬
#    **고장난 스택**을 잰 값이었다. 죽은 이미지가 6개 프로젝트를 막고 있었다.)
#   m6i.2xlarge(32GB) 에서 **여유는 5.5GB 뿐**이다 — 여유를 원하면 m6i.4xlarge(64GB).
instance_type = "m6i.2xlarge"

# (선택) 비우면 default VPC + 그 첫 퍼블릭 서브넷을 자동 탐색한다.
vpc_id    = ""
subnet_id = ""

# 본인 IP/32 로 좁힐 것. `0.0.0.0/0` 은 SSH 를 전 세계에 여는 것이다.
admin_ssh_cidr = "1.2.3.4/32"

# AMI 이미지 + 도커 레이어 + 96 컨테이너 로그.
root_volume_gb = 100

# 정적 사이트의 오리진으로 좁히는 것을 권장(CORS).
allowed_origin = "*"

# --- 지출 상한 --------------------------------------------------------------
# `/start` 는 **공개 엔드포인트**다. 가드 없이 두면 무제한 지출 버튼이 된다.
# 세 겹으로 막는다:
#   idle_minutes           — 마지막 하트비트 후 N 분 유휴면 정지
#   max_runtime_minutes    — 한 세션의 절대 상한(하트비트가 계속 와도 정지)
#   monthly_budget_minutes — **월 누적 가동 분**. 소진되면 `/start` 가 429 를 반환하고
#                            인스턴스를 켜지 않는다. 앞의 둘만으로는 부족하다 —
#                            누가 매일 세 시간씩 켜도 각 세션은 규칙을 지킨다.
idle_minutes           = 20
max_runtime_minutes    = 180
monthly_budget_minutes = 600
