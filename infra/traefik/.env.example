# Optional overrides — copy to .env if needed.

# Override Traefik HTTP port if 80 is taken on your machine.
# TRAEFIK_HTTP_PORT=8800

# Override Traefik HTTPS port if 443 is taken.
# TRAEFIK_HTTPS_PORT=8843

# Override Traefik dashboard port if 8080 is taken.
# TRAEFIK_DASHBOARD_PORT=8090

# Traefik log level: DEBUG | INFO | WARN | ERROR
# TRAEFIK_LOG_LEVEL=INFO
