{
  "name": "monorepo-lab",
  "private": true,
  "description": "Monorepo root — thin shortcut scripts that delegate runtimes to the owning project. No workspace / no dependencies at this level.",
  "scripts": {
    "ecommerce:install": "pnpm --dir projects/ecommerce-microservices-platform install",
    "ecommerce:dev": "pnpm --dir projects/ecommerce-microservices-platform dev",
    "ecommerce:build": "pnpm --dir projects/ecommerce-microservices-platform build",
    "ecommerce:lint": "pnpm --dir projects/ecommerce-microservices-platform lint",
    "ecommerce:web-store": "pnpm --dir projects/ecommerce-microservices-platform --filter web-store dev",
    "ecommerce:admin": "pnpm --dir projects/ecommerce-microservices-platform --filter admin-dashboard dev",
    "ecommerce:up": "docker compose --project-directory projects/ecommerce-microservices-platform up -d",
    "ecommerce:down": "docker compose --project-directory projects/ecommerce-microservices-platform down",
    "ecommerce:ps": "docker compose --project-directory projects/ecommerce-microservices-platform ps",
    "ecommerce:logs": "docker compose --project-directory projects/ecommerce-microservices-platform logs -f",
    "ecommerce:docker": "docker compose --project-directory projects/ecommerce-microservices-platform",
    "ecommerce:pnpm": "pnpm --dir projects/ecommerce-microservices-platform",
    "wms:up": "docker compose --project-directory projects/wms-platform up -d",
    "wms:bootrun": "docker compose --project-directory projects/wms-platform -f projects/wms-platform/docker-compose.yml -f projects/wms-platform/docker-compose.bootrun.yml up -d",
    "wms:down": "docker compose --project-directory projects/wms-platform down",
    "wms:ps": "docker compose --project-directory projects/wms-platform ps",
    "wms:logs": "docker compose --project-directory projects/wms-platform logs -f",
    "wms:docker": "docker compose --project-directory projects/wms-platform",
    "gap:install": "pnpm --dir projects/global-account-platform install",
    "gap:dev": "pnpm --dir projects/global-account-platform dev",
    "gap:build": "pnpm --dir projects/global-account-platform build",
    "gap:lint": "pnpm --dir projects/global-account-platform lint",
    "gap:admin-web": "pnpm --dir projects/global-account-platform --filter admin-web dev",
    "gap:up": "docker compose --project-directory projects/global-account-platform up -d",
    "gap:bootrun": "docker compose --project-directory projects/global-account-platform -f projects/global-account-platform/docker-compose.yml -f projects/global-account-platform/docker-compose.bootrun.yml up -d",
    "gap:down": "docker compose --project-directory projects/global-account-platform down",
    "gap:ps": "docker compose --project-directory projects/global-account-platform ps",
    "gap:logs": "docker compose --project-directory projects/global-account-platform logs -f",
    "gap:docker": "docker compose --project-directory projects/global-account-platform",
    "gap:pnpm": "pnpm --dir projects/global-account-platform",
    "traefik:up": "docker compose -f infra/traefik/docker-compose.yml up -d",
    "traefik:down": "docker compose -f infra/traefik/docker-compose.yml down",
    "traefik:ps": "docker compose -f infra/traefik/docker-compose.yml ps",
    "traefik:logs": "docker compose -f infra/traefik/docker-compose.yml logs -f",
    "fan-platform:up": "docker compose --project-directory projects/fan-platform up -d",
    "fan-platform:down": "docker compose --project-directory projects/fan-platform down",
    "fan-platform:ps": "docker compose --project-directory projects/fan-platform ps",
    "fan-platform:logs": "docker compose --project-directory projects/fan-platform logs -f",
    "fan-platform:docker": "docker compose --project-directory projects/fan-platform"
  }
}
